        "aboutSection": { "type": "object" },
        "whatWeDo": { "type": "object" },
        "visionSection": { "type": "object" },
        "whySection": { "type": "object" },
        "founderSpotlight": { "type": "object" },
        "contactSection": { "type": "object" },
        "footer": { "type": "object" }
      }
